{
  "manifest_version": 3,
  "name": "YT Music Playlist Enhancer",
  "version": "1.0.1",
  "description": "Tag, search, and manage your YouTube Music playlists easily. Find duplicates and export your data.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "activeTab",
    "contextMenus",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "https://ws.audioscrobbler.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "fuse.basic.min.js",
        "tagger.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}